# PostgreSQL Configuration
POSTGRES_DB=postgres
POSTGRES_USER=nauth_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# Tenant Databases
NAUTH_DB=nauth_db
VIRALT_DB=viralt_db

# Default Tenant
DEFAULT_TENANT_ID=nauth

# JWT Configuration (per tenant)
JWT_SECRET=your_global_jwt_secret_at_least_64_characters_long
NAUTH_JWT_SECRET=your_nauth_jwt_secret_at_least_64_characters_long
VIRALT_JWT_SECRET=your_viralt_jwt_secret_at_least_64_characters_long

# NAuth API Configuration
API_HTTP_PORT=5004
API_HTTPS_PORT=5005
CERTIFICATE_PASSWORD=your_certificate_password_here

# External Services
ZTOOL_API_URL=http://ztools-api:8080
BUCKET_NAME=Emagine
