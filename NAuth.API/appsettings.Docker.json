{
  "Tenant": {
    "DefaultTenantId": "${Tenant__DefaultTenantId}"
  },
  "Tenants": {
    "${Tenant__DefaultTenantId}": {
      "ConnectionString": "${ConnectionStrings__NAuthContext}",
      "JwtSecret": "${NAuth__JwtSecret}"
    }
  },
  "zTools": {
    "ApiURL": "http://ztools-api:8080"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "NAuth": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true,
      "TimestampFormat": "[yyyy-MM-dd HH:mm:ss] ",
      "LogLevel": {
        "Default": "Information",
        "NAuth": "Information"
      }
    }
  }
}